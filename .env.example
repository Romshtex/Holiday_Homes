# ──────────────────────────────────────────────
# Telegram Bot
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated list of admin Telegram user IDs
ADMIN_IDS=123456789,987654321

# ──────────────────────────────────────────────
# OpenAI
# ──────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Model used for text analytics
OPENAI_TEXT_MODEL=gpt-4o
# Model used for image generation
OPENAI_IMAGE_MODEL=dall-e-3

# ──────────────────────────────────────────────
# Scheduler (APScheduler)
# ──────────────────────────────────────────────
# Timezone for all cron jobs
SCHEDULER_TIMEZONE=Europe/Istanbul
# Hour (0-23) to publish the daily news digest
NEWS_PUBLISH_HOUR=9
# Minute (0-59) to publish the daily news digest
NEWS_PUBLISH_MINUTE=0

# ──────────────────────────────────────────────
# Parser
# ──────────────────────────────────────────────
# Comma-separated RSS feed URLs to monitor
RSS_FEEDS=https://www.dailysabah.com/rss,https://www.hurriyet.com.tr/rss/anasayfa
# Maximum number of news items to include in each digest
MAX_NEWS_ITEMS=5

# ──────────────────────────────────────────────
# Channel / Chat
# ──────────────────────────────────────────────
# Telegram channel ID or @username where news will be published
TARGET_CHANNEL_ID=@your_channel_username
